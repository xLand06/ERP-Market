# =============================================================================
# ERP-MARKET — Variables de Entorno (Desktop / Electron)
# Estas se configuran automáticamente, pero puedes override si quieres
# =============================================================================

# ─── APP ─────────────────────────────────────────────────────────────────────
# Nombre de la app (para electron-store)
APP_NAME=erp-market-desktop

# ─── MODO OFFLINE ( SQLite ) ────────────────────────────────────────────────
# No necesitas configurar nada - se genera automáticamente en AppData
# La DB se crea en: %APPDATA%/erp-market-desktop/erp-market.db

# ─── INTERVALO DE SYNC ────────────────────────────────────────────────
# Intervalo de sincronización con la nube en ms (default: 300000 = 5 min)
# SYNC_INTERVAL=300000