# =============================================================================
# ERP-MARKET — Variables de Entorno por Instalación
# Copia este archivo como .env y configura los valores correctos.
# =============================================================================

# ─── IDENTIFICADOR DE SUCURSAL ────────────────────────────────────────────────
# Define qué sucursal es esta instalación.
# Ejemplo de valores:
#   branch-sede-a     → Sucursal A
#   branch-sede-b     → Sucursal B
#   (vacío o no definido) → Instalación del dueño (ve todo)
BRANCH_ID=

# ─── NOMBRE DEL APP ──────────────────────────────────────────────────────────
APP_NAME=erp-market-desktop

# ─── NUBE (Supabase) ──────────────────────────────────────────────────────────
# Requerido para sincronización. Si no se configura, la app funciona 100% offline.
DATABASE_URL=
DIRECT_URL=

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Debe ser el mismo valor que usa el backend central.
JWT_SECRET=changeme_MINIMO_32_caracteres_aqui_

# ─── INTERVALO DE SYNC ───────────────────────────────────────────────────────
# Intervalo de sincronización en ms (default: 900000 = 15 min)
# SYNC_INTERVAL=900000
