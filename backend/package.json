{
    "name": "erp-market-backend",
    "version": "1.0.0",
    "private": true,
    "main": "src/server.ts",
    "scripts": {
        "dev": "nodemon src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "db:generate": "prisma generate",
        "db:generate:local": "prisma generate --schema=prisma/schema.local.prisma",
        "db:migrate": "prisma migrate dev",
        "db:push": "prisma db push",
        "db:push:local": "prisma db push --schema=prisma/schema.local.prisma",
        "db:studio": "prisma studio",
        "db:studio:local": "prisma studio --schema=prisma/schema.local.prisma",
        "db:seed": "ts-node prisma/seed.ts",
        "db:seed:local": "LOCAL_DATABASE_URL=file:./erp-market-dev.db ts-node prisma/seed.local.ts",
        "db:reset": "prisma migrate reset --force && ts-node prisma/seed.ts"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    },
    "dependencies": {
        "@prisma/client": "^6.0.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.21.0",
        "jsonwebtoken": "^9.0.2"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/node": "^22.0.0",
        "nodemon": "^3.1.4",
        "prisma": "^6.0.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.5.4"
    }
}