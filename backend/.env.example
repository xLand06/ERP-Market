# =============================================================================
# ERP-MARKET — Variables de Entorno (Backend)
# Copia este archivo a .env y completa los valores
# =============================================================================

# ─── SERVIDOR ────────────────────────────────────────────────────────────────
PORT=3000

# ─── BASE DE DATOS CLOUD (Supabase PostgreSQL) ────────────────────────────────
# Obtén el URI de: Supabase Dashboard → Settings → Database → Connection string
# Formato: postgresql://postgres:[password]@db.xxx.supabase.co:5432/postgres
DATABASE_URL=

# ─── SQLite LOCAL (modo offline / Electron) ────────────────────────────────────────
# No necesitas change esta - se genera automáticamente
LOCAL_DATABASE_URL=file:./erp-market.db

# ─── AUTENTICACIÓN ────────────────────────────────────────────────────────────────
# Secret para JWT ( mínimo 32 caracteres )
JWT_SECRET=changeme_MINIMO_32_caracteres_aqui_

# ─── ENTORNO ────────────────────────────────────────────────────────────────
# development | production
NODE_ENV=development

# ─── LOGGER ────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=debug

# ─── CORS ────────────────────────────────────────────────────────────────
# URL del frontend (para producción)
FRONTEND_URL=http://localhost:5175