// =============================================================================
// ERP-MARKET - SCHEMA COMPLETO (Prisma 7.x + Supabase)
// Login by username + Venezuela cedula (V/E)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum Role {
  OWNER
  SELLER
}

enum TransactionType {
  SALE
  INVENTORY_IN
}

enum TransactionStatus {
  COMPLETED
  CANCELLED
  PENDING
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  RECEIVED
  CANCELLED
}

enum SyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum CedulaType {
  V
  E
}

enum MermaReason {
  DAMAGED
  EXPIRED
  SOBRANTE
  BAD_CONDITION
OTHER
}

// =============================================================================
// USERS (AUTH)
// =============================================================================

model User {
  id         String     @id @default(cuid())
  username   String     @unique
  cedula     String
  cedulaType CedulaType @default(V)
  nombre     String
  apellido   String?
  email      String?
  password   String
  telefono   String?
  role       Role       @default(SELLER)
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now()) @db.Timestamptz
  updatedAt  DateTime   @updatedAt @db.Timestamptz

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

transactions  Transaction[]
cashRegisters CashRegister[]
auditLogs     AuditLog[]
mermas        Merma[] @relation("MermaCreatedBy")

@@index([username])
  @@index([cedula])
  @@index([role])
  @@index([isActive])
  @@index([branchId])
  @@map("users")
}

// =============================================================================
// BRANCHES
// =============================================================================

model Branch {
  id        String    @id @default(cuid())
  name      String
  code      String    @unique // Ej: 'V-01', 'CCS-02'
  address   String?
  phone     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt     @db.Timestamptz

  users          User[]
  inventory      BranchInventory[]
  transactions   Transaction[]
  cashRegisters  CashRegister[]
  purchaseOrders PurchaseOrder[]
  mermas         Merma[]

  @@index([isActive])
  @@map("branches")
}

// =============================================================================
// GROUPS
// =============================================================================

model Group {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  subGroups SubGroup[]

  @@map("groups")
}

model SubGroup {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  groupId String
  group   Group   @relation(fields: [groupId], references: [id])

  products Product[]

  @@unique([name, groupId])
  @@index([groupId])
  @@map("sub_groups")
}

// =============================================================================
// PRODUCTS
// =============================================================================

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  /// @deprecated — usar barcodes relation
  barcode     String?  @unique
  price       Decimal  @db.Decimal(12, 2) // en COP (moneda principal)
  cost        Decimal? @db.Decimal(12, 2) // en COP (moneda principal)
  baseUnit    String   @default("UNIDAD")
imageUrl    String?
  isActive    Boolean  @default(true)
  expectedSpoilagePercent Decimal? @db.Decimal(5, 2) // % merma esperada (ej: 5.00 = 5%)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  subGroupId String?
  subGroup   SubGroup? @relation(fields: [subGroupId], references: [id])

  barcodes           ProductBarcode[]
  presentations      ProductPresentation[]
  inventory          BranchInventory[]
  transactionItems   TransactionItem[]
  purchaseOrderItems PurchaseOrderItem[]
  mermas            Merma[]

  @@index([name])
  @@index([subGroupId])
  @@index([isActive])
  @@index([barcode])
  @@map("products")
}

model ProductPresentation {
  id         String  @id @default(cuid())
  name       String
  multiplier Decimal @db.Decimal(12, 3)
  price      Decimal @db.Decimal(12, 2) // en COP (moneda principal)
  barcode    String? @unique

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  transactionItems TransactionItem[]

  @@index([productId])
  @@index([barcode])
  @@map("product_presentations")
}

// Múltiples códigos de barras por producto (EAN, interno, proveedor, etc.)
model ProductBarcode {
  id    String  @id @default(cuid())
  code  String  @unique
  label String? // Ej: "EAN-13", "Interno", "Proveedor"

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([code])
  @@map("product_barcodes")
}

// =============================================================================
// INVENTORY BY BRANCH
// =============================================================================

model BranchInventory {
  id        String   @id @default(cuid())
  stock     Decimal  @default(0) @db.Decimal(12, 3)
  minStock  Decimal  @default(0) @db.Decimal(12, 3)
  updatedAt DateTime @updatedAt @db.Timestamptz

  productId String
  product   Product @relation(fields: [productId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  @@unique([productId, branchId])
  @@index([branchId])
  @@index([stock])
  @@index([branchId, stock])
  @@map("branch_inventory")
}

// =============================================================================
// TRANSACTIONS
// =============================================================================

model Transaction {
  id             String            @id @default(cuid())
  type           TransactionType
  status         TransactionStatus @default(COMPLETED)
  total          Decimal           @db.Decimal(12, 2) // siempre en COP
  notes          String?
  ipAddress      String?
  syncStatus     SyncStatus        @default(PENDING)
  syncedAt       DateTime?         @db.Timestamptz
  createdAt      DateTime          @default(now()) @db.Timestamptz
  updatedAt      DateTime          @updatedAt @db.Timestamptz

  // Multi-moneda
  currency       String?           // 'COP' | 'USD' | 'VES' — moneda en la que se realizó
  exchangeRate   Decimal?          @db.Decimal(18, 4) // tasa COP/currency usada al momento
  invoiceNumber  String?           // Nº factura (para INVENTORY_IN)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  cashRegisterId String?
  cashRegister   CashRegister? @relation(fields: [cashRegisterId], references: [id])

  items TransactionItem[]

  @@index([branchId, createdAt])
  @@index([userId])
  @@index([cashRegisterId])
  @@index([type, status])
  @@index([syncStatus])
  @@index([createdAt])
  @@map("transactions")
}

model TransactionItem {
  id             String  @id @default(cuid())
  quantity       Decimal @db.Decimal(12, 3)
  multiplierUsed Decimal @default(1) @db.Decimal(12, 3)
  unitPrice      Decimal @db.Decimal(12, 2)
  subtotal       Decimal @db.Decimal(12, 2)

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  presentationId String?
  presentation   ProductPresentation? @relation(fields: [presentationId], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@index([productId])
  @@index([presentationId])
  @@map("transaction_items")
}

// =============================================================================
// CASH REGISTER
// =============================================================================

model CashRegister {
  id             String             @id @default(cuid())
  status         CashRegisterStatus @default(OPEN)
  openingAmount  Decimal            @db.Decimal(12, 2)
  closingAmount  Decimal?           @db.Decimal(12, 2)
  expectedAmount Decimal?           @db.Decimal(12, 2)
  difference     Decimal?           @db.Decimal(12, 2)
  notes          String?
  syncStatus     SyncStatus         @default(PENDING)
  syncedAt       DateTime?          @db.Timestamptz
  openedAt       DateTime           @default(now()) @db.Timestamptz
  closedAt       DateTime?          @db.Timestamptz

  userId String
  user   User   @relation(fields: [userId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  transactions Transaction[]

  @@index([branchId])
  @@index([userId])
  @@index([status])
  @@index([syncStatus])
  @@map("cash_registers")
}

// =============================================================================
// AUDIT LOGS
// =============================================================================

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  module    String
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now()) @db.Timestamptz

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([module])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================================
// SUPPLIERS
// =============================================================================

model Supplier {
  id        String   @id @default(cuid())
  name      String
  rut       String?  @unique
  email     String?
  telefono  String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

// =============================================================================
// PURCHASE ORDERS
// =============================================================================

model PurchaseOrder {
  id         String              @id @default(cuid())
  status     PurchaseOrderStatus @default(DRAFT)
  total      Decimal             @db.Decimal(12, 2)
  notes      String?
  expectedAt DateTime?           @db.Timestamptz
  receivedAt DateTime?           @db.Timestamptz
  createdAt  DateTime            @default(now()) @db.Timestamptz
  updatedAt  DateTime            @updatedAt @db.Timestamptz

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  items PurchaseOrderItem[]

  @@index([supplierId])
  @@index([branchId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String  @id @default(cuid())
  quantity         Decimal @db.Decimal(12, 3)
  quantityReceived Decimal @default(0) @db.Decimal(12, 3)
  unitCost         Decimal @db.Decimal(12, 2)
  subtotal         Decimal @db.Decimal(12, 2)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

// =============================================================================
// EXCHANGE RATES
// =============================================================================

model ExchangeRate {
  id        String   @id @default(cuid())
  code      String   @unique // 'VES', 'COP', etc.
  rate      Decimal  @db.Decimal(18, 4)
  updatedAt DateTime @updatedAt

  @@map("exchange_rates")
}

// =============================================================================
// MERMA (SPOILAGE)
// =============================================================================

model Merma {
  id            String      @id @default(cuid())
  createdAt     DateTime    @default(now()) @db.Timestamptz
  updatedAt     DateTime   @updatedAt @db.Timestamptz
  branchId      String
  productId     String
  quantity      Decimal     @db.Decimal(12, 3)
  reason        MermaReason
  description   String?
  syncStatus    SyncStatus  @default(PENDING)

  branch     Branch    @relation(fields: [branchId], references: [id])
  product    Product   @relation(fields: [productId], references: [id])
  createdBy  User      @relation("MermaCreatedBy", fields: [createdById], references: [id])

  createdById String

  @@index([branchId, createdAt])
  @@index([productId])
  @@index([reason])
  @@index([syncStatus])
  @@map("mermas")
}
