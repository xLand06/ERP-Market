# =============================================================================
# ERP-MARKET — Variables de Entorno (Frontend)
# Copia este archivo a .env y completa los valores
# =============================================================================

# ─── API ─────────────────────────────────────────────────────────────────
# URL del backend (Express local o cloud)
# Desarrollo local (Electron): http://127.0.0.1:3001
# Desarrollo web: http://localhost:3000
# Producción cloud: https://tu-backend.onrender.com
VITE_API_URL=http://127.0.0.1:3001

# ─── BACKEND (para proxy en desarrollo) ─────────────────────────────────────────
# Solo necesario si usas proxy de Vite
VITE_BACKEND_URL=http://localhost:3000